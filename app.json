{
  "expo": {
    "name": "FocusFlow",
    "slug": "focusflow",
    "scheme": "focusflow",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.focusflow.app",
      "infoPlist": {
        "NSCalendarsUsageDescription": "FocusFlow needs calendar access for scheduling",
        "NSRemindersUsageDescription": "FocusFlow needs reminders for daily check-ins"
      }
    },
    "android": { "package": "com.focusflow.app" },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ],
      [
        "react-native-purchases",
        {
          "ios": {
            "appDelegateProxyEnabled": true
          }
        }
      ]
    ]
  }
}
